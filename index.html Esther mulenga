<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Esther ✨ — Mr. Mulenga</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Dancing+Script:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --rose:#e8a0b0; --deep-rose:#c2586e; --blush:#f9e4ea;
    --gold:#d4af7a; --cream:#fdf6f0; --dark:#1a0a10;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{background:var(--dark);color:var(--cream);font-family:'Cormorant Garamond',serif;overflow-x:hidden;cursor:none;}

  .cursor{width:18px;height:18px;background:radial-gradient(circle,#ff6b8a,#e8a0b0);border-radius:50%;position:fixed;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);mix-blend-mode:screen;}
  .cursor-trail{width:7px;height:7px;background:rgba(232,160,176,0.5);border-radius:50%;position:fixed;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:left 0.12s ease,top 0.12s ease;}
  #hearts-canvas{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;}
  section{position:relative;z-index:1;}

  /* ===== HERO ===== */
  #hero {
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    padding:60px 20px 80px;
    background:radial-gradient(ellipse at 50% 30%,#3d0a1e 0%,#1a0a10 65%);
    overflow:hidden;
    text-align:center;
  }
  .ring{position:absolute;border-radius:50%;border:1px solid rgba(232,160,176,0.12);animation:pulseRing 5s ease-in-out infinite;}
  .ring:nth-child(1){width:380px;height:380px;animation-delay:0s}
  .ring:nth-child(2){width:640px;height:640px;animation-delay:1s}
  .ring:nth-child(3){width:900px;height:900px;animation-delay:2s}
  .ring:nth-child(4){width:1160px;height:1160px;animation-delay:3s}
  @keyframes pulseRing{0%,100%{opacity:0.08;transform:scale(1)}50%{opacity:0.25;transform:scale(1.03)}}

  .hero-eyebrow{font-family:'Dancing Script',cursive;font-size:clamp(1rem,3vw,1.4rem);color:var(--gold);letter-spacing:6px;margin-bottom:16px;opacity:0;animation:fadeUp 1s 0.4s forwards;}
  .hero-name{font-family:'Playfair Display',serif;font-size:clamp(4.5rem,15vw,10rem);font-weight:700;font-style:italic;line-height:1;background:linear-gradient(135deg,#f9e4ea 0%,#e8a0b0 30%,#d4af7a 60%,#e8a0b0 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:300%;opacity:0;animation:fadeUp 1s 0.8s forwards,shimmer 5s 2s linear infinite;margin-bottom:8px;}
  .hero-tagline{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(0.9rem,2.5vw,1.2rem);color:rgba(249,228,234,0.6);letter-spacing:3px;margin-bottom:44px;opacity:0;animation:fadeUp 1s 1.2s forwards;}

  /* Single centered hero photo */
  .hero-photo-wrap{
    position:relative;
    display:inline-block;
    margin-bottom:44px;
    opacity:0;
    animation:zoomIn 1.2s 1.6s cubic-bezier(0.34,1.56,0.64,1) forwards;
  }
  /* Outer spinning glow */
  .hero-photo-wrap::before{
    content:'';
    position:absolute;
    inset:-16px;
    border-radius:32px;
    background:conic-gradient(from 0deg,#e8a0b0,#d4af7a,#f9e4ea,#c2586e,#e8a0b0);
    animation:spinGlow 5s linear infinite;
    z-index:-1;
    filter:blur(10px);
    opacity:0.85;
  }
  /* Soft ambient halo */
  .hero-photo-wrap::after{
    content:'';
    position:absolute;
    inset:-40px;
    border-radius:50px;
    background:radial-gradient(ellipse,rgba(232,160,176,0.25),transparent 70%);
    z-index:-2;
    animation:breathe 4s ease-in-out infinite;
  }
  @keyframes breathe{0%,100%{opacity:0.6;transform:scale(1)}50%{opacity:1;transform:scale(1.05)}}
  .hero-photo{
    width:min(300px,78vw);
    height:min(380px,96vw);
    object-fit:cover;
    object-position:top;
    border-radius:26px;
    display:block;
    border:3px solid rgba(232,160,176,0.25);
    box-shadow:0 40px 90px rgba(0,0,0,0.65), 0 0 70px rgba(232,160,176,0.12);
  }
  .hero-badge{
    position:absolute;
    bottom:-20px;
    left:50%;
    transform:translateX(-50%);
    background:linear-gradient(135deg,#c2586e,#e8a0b0);
    color:white;
    font-family:'Dancing Script',cursive;
    font-size:1.3rem;
    padding:9px 30px;
    border-radius:100px;
    white-space:nowrap;
    box-shadow:0 8px 28px rgba(194,88,110,0.55);
    letter-spacing:2px;
  }
  @keyframes spinGlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  @keyframes zoomIn{from{opacity:0;transform:scale(0.6)}to{opacity:1;transform:scale(1)}}

  .hero-desc{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(1rem,2.5vw,1.3rem);color:rgba(249,228,234,0.7);max-width:480px;line-height:2;opacity:0;animation:fadeUp 1s 2.8s forwards;margin-top:36px;}
  .scroll-hint{position:absolute;bottom:28px;display:flex;flex-direction:column;align-items:center;gap:8px;opacity:0;animation:fadeIn 1s 3.6s forwards;}
  .scroll-hint span{font-family:'Dancing Script',cursive;color:var(--gold);font-size:0.85rem;letter-spacing:3px;}
  .scroll-arrow{width:18px;height:18px;border-right:2px solid var(--gold);border-bottom:2px solid var(--gold);transform:rotate(45deg);animation:bounce 1.5s ease-in-out infinite;}
  @keyframes bounce{0%,100%{transform:rotate(45deg) translateY(0)}50%{transform:rotate(45deg) translateY(6px)}}

  /* ===== GALLERY ===== */
  #gallery{padding:80px 20px;background:linear-gradient(180deg,#1a0a10,#0f0508 50%,#1a0a10);}
  .section-title{text-align:center;margin-bottom:60px;}
  .section-title .tag{font-family:'Dancing Script',cursive;color:var(--gold);font-size:1.2rem;display:block;margin-bottom:10px;letter-spacing:3px;}
  .section-title h2{font-family:'Playfair Display',serif;font-size:clamp(2rem,6vw,4rem);font-style:italic;background:linear-gradient(135deg,#f9e4ea,#e8a0b0);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .gallery-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;max-width:1100px;margin:0 auto;}
  .photo-card{position:relative;border-radius:20px;overflow:hidden;cursor:pointer;transform:translateY(60px);opacity:0;transition:transform 0.6s cubic-bezier(0.34,1.56,0.64,1),opacity 0.6s,box-shadow 0.4s;}
  .photo-card.visible{transform:translateY(0);opacity:1;}
  .photo-card:hover{box-shadow:0 30px 60px rgba(232,160,176,0.3),0 0 0 2px var(--rose);transform:translateY(-8px) scale(1.01);}
  .photo-card img{width:100%;height:360px;object-fit:cover;object-position:top;display:block;transition:transform 0.6s;filter:brightness(0.9) saturate(1.1);}
  .photo-card:hover img{transform:scale(1.06);}
  .photo-card .overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(26,10,16,0.9) 0%,transparent 60%);opacity:0;transition:opacity 0.4s;display:flex;align-items:flex-end;padding:24px;}
  .photo-card:hover .overlay{opacity:1;}
  .overlay-text{font-family:'Dancing Script',cursive;font-size:1.3rem;color:var(--blush);transform:translateY(10px);transition:transform 0.4s 0.1s;}
  .photo-card:hover .overlay-text{transform:translateY(0);}
  .photo-card .heart-badge{position:absolute;top:16px;right:16px;font-size:1.5rem;opacity:0;transform:scale(0);transition:all 0.3s 0.1s;}
  .photo-card:hover .heart-badge{opacity:1;transform:scale(1);}

  /* ===== PROPOSAL ===== */
  #proposal{
    padding:100px 20px;
    background:radial-gradient(ellipse at 50% 50%,#3d0a1e 0%,#1a0a10 70%);
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  #proposal::before{content:'💍';position:absolute;font-size:260px;opacity:0.04;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;}
  .proposal-ring-emoji{font-size:64px;display:block;margin:0 auto 24px;animation:ringPulse 2s ease-in-out infinite;opacity:0;transition:opacity 0.8s;}
  .proposal-ring-emoji.visible{opacity:1;}
  @keyframes ringPulse{0%,100%{transform:scale(1) rotate(-5deg)}50%{transform:scale(1.25) rotate(5deg)}}
  .proposal-from{font-family:'Dancing Script',cursive;color:var(--gold);font-size:1rem;letter-spacing:4px;display:block;margin-bottom:24px;opacity:0;transition:opacity 0.8s 0.2s;}
  .proposal-from.visible{opacity:1;}
  .proposal-photo{width:130px;height:130px;border-radius:50%;object-fit:cover;object-position:top;margin:0 auto 36px;display:block;border:3px solid var(--rose);box-shadow:0 0 50px rgba(232,160,176,0.5);opacity:0;transform:scale(0.7);transition:opacity 0.8s 0.3s,transform 0.8s 0.3s cubic-bezier(0.34,1.56,0.64,1);}
  .proposal-photo.visible{opacity:1;transform:scale(1);}
  .proposal-quote{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(2rem,6vw,4.5rem);line-height:1.25;background:linear-gradient(135deg,#f9e4ea,#e8a0b0,#d4af7a,#e8a0b0,#f9e4ea);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;background-size:300%;animation:shimmer 4s linear infinite;max-width:750px;margin:0 auto 30px;opacity:0;transform:scale(0.9);transition:opacity 0.8s 0.5s,transform 0.8s 0.5s cubic-bezier(0.34,1.56,0.64,1);}
  .proposal-quote.visible{opacity:1;transform:scale(1);}
  .proposal-signed{font-family:'Dancing Script',cursive;color:var(--rose);font-size:clamp(1.2rem,3vw,1.8rem);opacity:0;transition:opacity 0.8s 0.9s;}
  .proposal-signed.visible{opacity:1;}
  .proposal-hearts{display:flex;justify-content:center;gap:20px;margin-top:44px;font-size:2.2rem;opacity:0;transition:opacity 0.8s 1.1s;}
  .proposal-hearts.visible{opacity:1;}
  .proposal-hearts span{display:inline-block;animation:heartFloat 2s ease-in-out infinite;}
  .proposal-hearts span:nth-child(1){animation-delay:0s}
  .proposal-hearts span:nth-child(2){animation-delay:0.3s}
  .proposal-hearts span:nth-child(3){animation-delay:0.6s}
  .proposal-hearts span:nth-child(4){animation-delay:0.9s}
  .proposal-hearts span:nth-child(5){animation-delay:1.2s}
  @keyframes heartFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

  /* ===== LETTERS ===== */
  #letters{padding:80px 20px;background:radial-gradient(ellipse at 30% 50%,#2a0a18 0%,#0f0508 60%);}
  .letters-wrapper{max-width:700px;margin:0 auto;display:flex;flex-direction:column;gap:40px;}
  .letter-card{background:rgba(255,255,255,0.03);border:1px solid rgba(232,160,176,0.2);border-radius:20px;padding:40px;position:relative;transform:translateX(-60px);opacity:0;transition:all 0.7s cubic-bezier(0.34,1.56,0.64,1);backdrop-filter:blur(10px);}
  .letter-card:nth-child(even){transform:translateX(60px);}
  .letter-card.visible{transform:translateX(0);opacity:1;}
  .letter-card::before{content:'"';position:absolute;top:-10px;left:24px;font-family:'Playfair Display',serif;font-size:80px;color:var(--rose);opacity:0.3;line-height:1;}
  .letter-number{font-family:'Dancing Script',cursive;color:var(--gold);font-size:0.9rem;letter-spacing:3px;margin-bottom:16px;display:block;}
  .letter-text{font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,2.5vw,1.25rem);line-height:1.9;color:rgba(249,228,234,0.85);font-style:italic;}
  .letter-sign{text-align:right;margin-top:20px;font-family:'Dancing Script',cursive;color:var(--rose);font-size:1.2rem;}

  /* ===== SPARKS ===== */
  #sparks{padding:100px 20px;text-align:center;background:linear-gradient(180deg,#0f0508,#1a0a10);}
  .spark-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:16px;max-width:800px;margin:60px auto 0;}
  .spark-pill{padding:12px 28px;border:1px solid rgba(232,160,176,0.3);border-radius:100px;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(0.9rem,2vw,1.1rem);color:var(--blush);background:rgba(232,160,176,0.05);transform:scale(0.8);opacity:0;transition:all 0.5s cubic-bezier(0.34,1.56,0.64,1);}
  .spark-pill.visible{transform:scale(1);opacity:1;}
  .spark-pill:hover{background:rgba(232,160,176,0.15);border-color:var(--rose);transform:scale(1.08);box-shadow:0 0 20px rgba(232,160,176,0.2);}

  /* ===== FOOTER ===== */
  #footer{padding:80px 20px 60px;text-align:center;background:radial-gradient(ellipse at 50% 80%,#3a0a1a,#0f0508);}
  .big-heart{font-size:80px;display:block;margin:0 auto 24px;animation:heartbeat 1.5s ease-in-out infinite;}
  @keyframes heartbeat{0%,100%{transform:scale(1)}14%{transform:scale(1.15)}28%{transform:scale(1)}42%{transform:scale(1.1)}70%{transform:scale(1)}}
  .footer-quote{font-family:'Playfair Display',serif;font-style:italic;font-size:clamp(1.3rem,4vw,2.2rem);color:var(--blush);max-width:600px;margin:0 auto 24px;line-height:1.6;}
  .footer-sub{font-family:'Dancing Script',cursive;color:var(--gold);font-size:1.1rem;letter-spacing:3px;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
  @keyframes shimmer{0%{background-position:0% 50%}100%{background-position:300% 50%}}
  @keyframes fadeIn{from{opacity:0}to{opacity:1}}
  .sparkle{position:fixed;pointer-events:none;font-size:1rem;animation:sparkleFloat 1.2s ease-out forwards;z-index:9997;}
  @keyframes sparkleFloat{0%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-80px) scale(0.3)}}
  .petal{position:fixed;pointer-events:none;z-index:0;animation:petalFall linear forwards;opacity:0.7;}
  @keyframes petalFall{0%{transform:translateY(-20px) rotate(0deg);opacity:0.7}100%{transform:translateY(110vh) rotate(360deg);opacity:0}}

  @media(max-width:600px){
    .hero-photo{width:min(260px,85vw);height:min(330px,90vw);}
    .gallery-grid{grid-template-columns:1fr 1fr;gap:12px;}
    .photo-card img{height:200px;}
    .letter-card{padding:28px 20px;}
  }
</style>
</head>
<body>
<div class="cursor" id="cursor"></div>
<div class="cursor-trail" id="cursorTrail"></div>
<canvas id="hearts-canvas"></canvas>

<!-- HERO -->
<section id="hero">
  <div class="ring"></div><div class="ring"></div><div class="ring"></div><div class="ring"></div>

  <p class="hero-eyebrow">✦ a world made just for ✦</p>
  <h1 class="hero-name">Esther</h1>
  <p class="hero-tagline">radiant · graceful · unforgettable</p>

  <div class="hero-photo-wrap">
    <img class="hero-photo" src="data:image/jpeg;base64," alt="Esther">
    <span class="hero-badge">✦ Esther ✦</span>
  </div>

  <p class="hero-desc">
    Some people walk into your world<br>
    and rearrange everything quietly —<br>
    like light through a window<br>
    you forgot you had.
  </p>

  <div class="scroll-hint">
    <span>scroll</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<!-- GALLERY -->
<section id="gallery">
  <div class="section-title">
    <span class="tag">✦ captured moments ✦</span>
    <h2>Esther's Gallery</h2>
  </div>
  <div class="gallery-grid">
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">Sunshine & grace ✨</span></div><span class="heart-badge">💖</span></div>
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">Peace signs & smiles ✌️</span></div><span class="heart-badge">🌸</span></div>
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">It's about time ⏳</span></div><span class="heart-badge">✨</span></div>
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">Squad & sunshine 🌺</span></div><span class="heart-badge">🌼</span></div>
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">Golden moment 🌟</span></div><span class="heart-badge">💝</span></div>
  
    <div class="photo-card"><img src="data:image/jpeg;base64," alt=""><div class="overlay"><span class="overlay-text">Esther & her sister 🌸</span></div><span class="heart-badge">👯</span></div></div>
</section>

<!-- PROPOSAL -->
<section id="proposal">
  <span class="proposal-ring-emoji">💍</span>
  <span class="proposal-from">— a message from the heart —</span>
  <img class="proposal-photo" src="data:image/jpeg;base64," alt="Esther">
  <p class="proposal-quote">"Make me your husband,<br>Mrs. Esther Mulenga."</p>
  <p class="proposal-signed">— with everything I have, Mr. Mulenga 💍</p>
  <div class="proposal-hearts">
    <span>💗</span><span>✨</span><span>💍</span><span>✨</span><span>💗</span>
  </div>
</section>

<!-- LETTERS -->
<section id="letters">
  <div class="section-title">
    <span class="tag">✦ words for Esther ✦</span>
    <h2>Little Letters</h2>
  </div>
  <div class="letters-wrapper">
    <div class="letter-card">
      <span class="letter-number">Letter No. 001</span>
      <p class="letter-text">Esther, there are people who make you feel seen — truly seen — without even trying. You are that person. The way you carry yourself, the way you smile even when the sun is too bright, the way you make ordinary places feel like somewhere worth remembering. That is a rare kind of magic.</p>
      <p class="letter-sign">— written with care 🌷</p>
    </div>
    <div class="letter-card">
      <span class="letter-number">Letter No. 002</span>
      <p class="letter-text">Your peace signs and your laughter — they are not small things. They are the kind of details someone holds onto long after the moment has passed. You have a way of making every photo feel like a story, and every story feel like somewhere warm.</p>
      <p class="letter-sign">— always grateful 🌸</p>
    </div>
    <div class="letter-card">
      <span class="letter-number">Letter No. 003</span>
      <p class="letter-text">Your shirt said "it's about time" — and maybe it was right. Some things arrive exactly when they are supposed to. Patient like the seasons, soft like the light in all your pictures, and worth every single moment.</p>
      <p class="letter-sign">— quietly yours 🍃</p>
    </div>
    <div class="letter-card">
      <span class="letter-number">Letter No. 004</span>
      <p class="letter-text">Esther, you stand in parks and hillsides like you belong everywhere beautiful. And you do. The green around you, the pink flowers overhead — even nature arranges itself just so whenever you are near. That is not a coincidence. That is you.</p>
      <p class="letter-sign">— forever noticing 💛</p>
    </div>
  </div>
</section>

<!-- SPARKS -->
<section id="sparks">
  <div class="section-title">
    <span class="tag">✦ little truths ✦</span>
    <h2>Things True About Esther</h2>
  </div>
  <div class="spark-grid">
    <div class="spark-pill">Her smile is contagious 🌸</div>
    <div class="spark-pill">She makes peace signs look poetic ✌️</div>
    <div class="spark-pill">She has a gift for being unforgettable ✨</div>
    <div class="spark-pill">Sunlight agrees with her 🌤️</div>
    <div class="spark-pill">She chooses the best outfits 👗</div>
    <div class="spark-pill">Her laugh changes rooms 🌺</div>
    <div class="spark-pill">She looks like a main character 💫</div>
    <div class="spark-pill">She carries quiet strength 🌿</div>
    <div class="spark-pill">Even candid shots look like art 📷</div>
    <div class="spark-pill">Esther is simply different 💖</div>
    <div class="spark-pill">She would make a wonderful Mrs. Mulenga 💍</div>
    <div class="spark-pill">Nature blooms when she arrives 🌼</div>
  </div>
</section>

<!-- FOOTER -->
<section id="footer">
  <span class="big-heart">💗</span>
  <p class="footer-quote">"Some people are just a feeling —<br>and Esther Mulenga has a beautiful ring to it."</p>
  <p class="footer-sub">✦ made with every good thing, just for her ✦</p>
</section>

<script>
const cursor=document.getElementById('cursor');
const trail=document.getElementById('cursorTrail');
let mouseX=0,mouseY=0;
document.addEventListener('mousemove',e=>{
  mouseX=e.clientX;mouseY=e.clientY;
  cursor.style.left=mouseX+'px';cursor.style.top=mouseY+'px';
  setTimeout(()=>{trail.style.left=mouseX+'px';trail.style.top=mouseY+'px';},80);
  spawnSparkle(e.clientX,e.clientY);
});
let sparkleTimer=0;
function spawnSparkle(x,y){
  if(Date.now()-sparkleTimer<100)return;
  sparkleTimer=Date.now();
  const emojis=['✨','💗','🌸','⭐','💫','🌺','💕','💍'];
  const el=document.createElement('div');
  el.className='sparkle';
  el.textContent=emojis[Math.floor(Math.random()*emojis.length)];
  el.style.left=(x+(Math.random()-0.5)*30)+'px';
  el.style.top=(y+(Math.random()-0.5)*30)+'px';
  document.body.appendChild(el);
  setTimeout(()=>el.remove(),1200);
}
document.addEventListener('click',e=>{
  const emojis=['💗','🌸','✨','💫','🌺','💕','💍','Mrs. Mulenga 💍'];
  for(let i=0;i<8;i++){
    setTimeout(()=>{
      const el=document.createElement('div');
      el.className='sparkle';
      el.textContent=emojis[Math.floor(Math.random()*emojis.length)];
      el.style.left=(e.clientX+(Math.random()-0.5)*80)+'px';
      el.style.top=(e.clientY+(Math.random()-0.5)*80)+'px';
      el.style.fontSize=(0.7+Math.random()*1)+'rem';
      document.body.appendChild(el);
      setTimeout(()=>el.remove(),1200);
    },i*60);
  }
});
const canvas=document.getElementById('hearts-canvas');
const ctx=canvas.getContext('2d');
canvas.width=window.innerWidth;canvas.height=window.innerHeight;
window.addEventListener('resize',()=>{canvas.width=window.innerWidth;canvas.height=window.innerHeight;});
const particles=[];
for(let i=0;i<45;i++){
  particles.push({x:Math.random()*window.innerWidth,y:Math.random()*window.innerHeight+window.innerHeight,size:8+Math.random()*16,speed:0.3+Math.random()*0.7,drift:(Math.random()-0.5)*0.5,opacity:0.1+Math.random()*0.25,emoji:['💗','🌸','✨','💫','🌺','💍'][Math.floor(Math.random()*6)]});
}
function animateParticles(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  particles.forEach(p=>{
    p.y-=p.speed;p.x+=p.drift;
    if(p.y<-50){p.y=canvas.height+50;p.x=Math.random()*canvas.width;}
    ctx.globalAlpha=p.opacity;ctx.font=p.size+'px serif';ctx.fillText(p.emoji,p.x,p.y);ctx.globalAlpha=1;
  });
  requestAnimationFrame(animateParticles);
}
animateParticles();
function spawnPetal(){
  const petals=['🌸','🌺','🌷','🌼','🍃','💍'];
  const el=document.createElement('div');
  el.className='petal';
  el.textContent=petals[Math.floor(Math.random()*petals.length)];
  el.style.left=Math.random()*100+'vw';
  el.style.top='-20px';
  const dur=6+Math.random()*6;
  el.style.animationDuration=dur+'s';
  el.style.fontSize=(0.8+Math.random()*0.8)+'rem';
  document.body.appendChild(el);
  setTimeout(()=>el.remove(),dur*1000);
}
setInterval(spawnPetal,800);
const observer=new IntersectionObserver(entries=>{
  entries.forEach(entry=>{
    if(entry.isIntersecting){
      setTimeout(()=>entry.target.classList.add('visible'),entry.target.dataset.delay||0);
    }
  });
},{threshold:0.15});
document.querySelectorAll('.photo-card').forEach((el,i)=>{el.dataset.delay=i*100;observer.observe(el);});
document.querySelectorAll('.letter-card').forEach((el,i)=>{el.dataset.delay=i*120;observer.observe(el);});
document.querySelectorAll('.spark-pill').forEach((el,i)=>{el.dataset.delay=i*60;observer.observe(el);});
document.querySelectorAll('.proposal-ring-emoji,.proposal-from,.proposal-quote,.proposal-signed,.proposal-hearts,.proposal-photo').forEach((el,i)=>{el.dataset.delay=i*200;observer.observe(el);});
document.addEventListener('touchstart',e=>{
  const touch=e.touches[0];
  const emojis=['💗','🌸','✨','💫','💍'];
  for(let i=0;i<5;i++){
    setTimeout(()=>{
      const el=document.createElement('div');el.className='sparkle';
      el.textContent=emojis[Math.floor(Math.random()*emojis.length)];
      el.style.left=(touch.clientX+(Math.random()-0.5)*60)+'px';
      el.style.top=(touch.clientY+(Math.random()-0.5)*60)+'px';
      document.body.appendChild(el);setTimeout(()=>el.remove(),1200);
    },i*80);
  }
});
</script>
